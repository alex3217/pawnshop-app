{
  "private": true,
  "scripts": {
    "check:dev-safe": "npm --prefix apps/web run check:dev-safe",
    "check:dev-wiring": "npm --prefix apps/web run check:dev-wiring",
    "build:web": "npm --prefix apps/web run build",
    "dev:web": "npm --prefix apps/web run dev",
    "check:app-flow": "bash scripts/check-app-flow.sh",
    "check:app-flow-full": "bash scripts/check-app-flow-full.sh",
    "check:payment-webhook": "bash scripts/check-payment-webhook.sh",
    "check:prod-readiness": "bash scripts/check-prod-readiness.sh",
    "pm2:dev": "pm2 startOrReload ecosystem.config.cjs --only pawn-dev-6002 --update-env",
    "pm2:staging": "pm2 startOrReload ecosystem.config.cjs --only pawn-staging-6003 --update-env",
    "pm2:prod": "pm2 startOrReload ecosystem.config.cjs --only pawn-prod-6001 --update-env",
    "check:deploy:dev": "bash scripts/check-deploy-health.sh http://127.0.0.1:6002",
    "check:deploy:staging": "bash scripts/check-deploy-health.sh http://127.0.0.1:6003",
    "check:deploy:prod": "bash scripts/check-deploy-health.sh http://127.0.0.1:6001",
    "db:backup:dev": "bash scripts/backup-db.sh apps/api/backend/.env.development",
    "db:backup:staging": "bash scripts/backup-db.sh apps/api/backend/.env.staging",
    "db:backup:prod": "bash scripts/backup-db.sh apps/api/backend/.env.production",
    "db:restore:dev": "bash scripts/restore-db.sh apps/api/backend/.env.development",
    "db:restore:staging": "bash scripts/restore-db.sh apps/api/backend/.env.staging",
    "db:restore:prod": "bash scripts/restore-db.sh apps/api/backend/.env.production",
    "check:staging-readiness": "bash scripts/check-staging-readiness.sh",
    "check:prod-preflight": "bash scripts/check-prod-preflight.sh",
    "check:prod-smoke": "bash scripts/check-prod-smoke.sh",
    "check:launch": "npm run check:prod-preflight && npm run check:deploy:prod && npm run check:prod-smoke",
    "check:domain": "bash scripts/check-domain-readiness.sh",
    "check:static-safety": "bash scripts/check-static-safety.sh",
    "check:processes": "bash scripts/check-process-boundaries.sh",
    "check:processes:frontend": "REQUIRE_FRONTEND=1 bash scripts/check-process-boundaries.sh",
    "check:frontend-routes": "bash scripts/check-frontend-routes-links.sh",
    "check:backend-routes": "bash scripts/check-backend-routes.sh",
    "check:role-routes": "bash scripts/check-role-routes.sh",
    "check:click-routes": "node scripts/playwright/route-click-audit.mjs",
    "check:all-routes": "npm run check:frontend-routes && npm run check:backend-routes && npm run check:role-routes && npm run check:click-routes",
    "check:super-admin-pages": "node scripts/playwright/super-admin-page-audit.mjs",
    "check:ai-listing-assistant": "bash scripts/check-ai-listing-assistant.sh"
  }
}
