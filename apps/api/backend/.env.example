# Runtime
APP_NAME=pawnloop-api
NODE_ENV=development
APP_ENV=development
PORT=6002
PAWN_PORT=6002
HOST=0.0.0.0
DOTENV_CONFIG_PATH=apps/api/backend/.env.development

# Networking / proxy
TRUST_PROXY=0

# URLs / CORS
FRONTEND_URL=https://pawnloop.com
WEB_URL=https://pawnloop.com
CORS_ORIGIN=https://pawnloop.com
CORS_ORIGINS=https://pawnloop.com,https://www.pawnloop.com

# Request limits
JSON_LIMIT=2mb
URLENCODED_LIMIT=2mb

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pawnshop?schema=public

# Health / readiness
READINESS_TIMEOUT_MS=5000

# Auth
JWT_SECRET=replace-with-long-random-secret
ACCESS_TOKEN_SECRET=replace-with-long-random-secret
JWT_ACCESS_SECRET=replace-with-long-random-secret
AUTH_SECRET=replace-with-long-random-secret
INTEGRATION_CREDENTIAL_ENCRYPTION_KEY=replace-with-long-random-32-byte-secret
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_DEFAULT_CURRENCY=usd
STRIPE_WEBHOOK_BODY_LIMIT=2mb

# Stripe seller subscription price IDs
STRIPE_PRICE_PRO=price_replace_me
STRIPE_PRICE_PREMIUM=price_replace_me
STRIPE_PRICE_ULTRA=price_replace_me
STRIPE_CONNECT_ENABLED=false

# Jobs / schedulers
AUCTION_SCHEDULER_ENABLED=false

# OpenAI / AI helpers
OPENAI_API_KEY=sk_replace_me
OPENAI_LISTING_MODEL=gpt-4o-mini
AI_LISTING_ASSISTANT_ENABLED=true


AUCTION_SCHEDULER_INTERVAL_MS=5000
AUCTION_SCHEDULER_BATCH_SIZE=50

# App metadata
APP_VERSION=development

# Combined frontend + API hosting
FRONTEND_HOSTS=pawnloop.com,www.pawnloop.com
SERVE_WEB=0
