generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                 @id @default(cuid())
  name                    String
  email                   String                 @unique
  password                String
  role                    Role                   @default(CONSUMER)
  isActive                Boolean                @default(true)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  Bid                     Bid[]
  buyerSubscription       BuyerSubscription?
  inventoryImportJobs     InventoryImportJob[]   @relation("UserInventoryImportJobs")
  inventoryIntegrations   InventoryIntegration[] @relation("UserInventoryIntegrations")
  buyerOffers             Offer[]                @relation("OfferBuyer")
  ownerOffers             Offer[]                @relation("OfferOwner")
  shops                   PawnShop[]
  savedSearches           SavedSearch[]          @relation("UserSavedSearches")
  wonSettlements          Settlement[]           @relation("SettlementWinner")
  watchlistEntries        Watchlist[]            @relation("UserWatchlist")
  buyerItemSubmissions    BuyerItemSubmission[]  @relation("BuyerItemSubmissions")
  buyerItemSubmissionOffers BuyerItemSubmissionOffer[] @relation("BuyerItemSubmissionOfferOwner")
  updatedPlatformSettings PlatformSetting[]      @relation("PlatformSettingUpdatedByUser")
  staffMemberships        Staff[]                @relation("StaffUser")

  @@index([role, isActive])
  @@index([createdAt])
}

model BuyerSubscription {
  id                      String                  @id @default(cuid())
  userId                  String                  @unique
  plan                    BuyerSubscriptionPlan   @default(FREE)
  status                  BuyerSubscriptionStatus @default(ACTIVE)
  billingInterval         BillingInterval?
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  startedAt               DateTime?
  canceledAt              DateTime?
  trialEndsAt             DateTime?
  cancelAtPeriodEnd       Boolean                 @default(false)
  stripeCustomerId        String?
  stripeSubscriptionId    String?                 @unique
  stripePriceId           String?
  stripeLatestInvoiceId   String?
  stripeCheckoutSessionId String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  user                    User                    @relation(fields: [userId], references: [id])

  @@index([plan, status])
  @@index([status, currentPeriodEnd])
  @@index([createdAt])
}

model PawnShop {
  id                           String                 @id @default(cuid())
  name                         String
  address                      String?
  phone                        String?
  description                  String?
  hours                        String?
  ownerId                      String
  isDeleted                    Boolean                @default(false)
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  cancelAtPeriodEnd            Boolean                @default(false)
  stripeCustomerId             String?
  stripeSubscriptionId         String?                @unique
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionPlan             String                 @default("FREE")
  subscriptionStatus           String                 @default("ACTIVE")
  stripeCheckoutSessionId      String?
  stripeLatestInvoiceId        String?
  stripePriceId                String?
  subscriptionBillingInterval  BillingInterval?
  subscriptionCanceledAt       DateTime?
  subscriptionStartedAt        DateTime?
  auctions                     Auction[]
  inventoryImportJobs          InventoryImportJob[]   @relation("ShopInventoryImportJobs")
  inventoryIntegrations        InventoryIntegration[] @relation("ShopInventoryIntegrations")
  items                        Item[]
  staffMembers                 Staff[]                @relation("ShopStaffMembers")
  owner                        User                   @relation(fields: [ownerId], references: [id])
  inventorySyncJobs            InventorySyncJob[]
  buyerItemSubmissionOffers    BuyerItemSubmissionOffer[] @relation("BuyerItemSubmissionOfferShop")

  @@index([ownerId, isDeleted])
  @@index([isDeleted, createdAt])
  @@index([subscriptionPlan, subscriptionStatus])
  @@index([subscriptionStatus, subscriptionCurrentPeriodEnd])
}

model Staff {
  id          String      @id @default(cuid())
  shopId      String
  userId      String?
  email       String
  name        String?
  phone       String?
  role        StaffRole   @default(SHOP_STAFF)
  status      StaffStatus @default(INVITED)
  permissions String[]    @default([])
  invitedAt   DateTime    @default(now())
  acceptedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  shop        PawnShop    @relation("ShopStaffMembers", fields: [shopId], references: [id], onDelete: Cascade)
  user        User?       @relation("StaffUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([shopId, email])
  @@index([shopId, status])
  @@index([shopId, role])
  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

model Item {
  id               String      @id @default(cuid())
  pawnShopId       String
  title            String
  description      String?
  price            Decimal     @db.Decimal(10, 2)
  images           String[]
  category         String?
  condition        String?
  status           ItemStatus  @default(AVAILABLE)
  isDeleted        Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  currency         String      @default("USD")
  auction          Auction?
  inquiries        Inquiry[]
  shop             PawnShop    @relation(fields: [pawnShopId], references: [id])
  offers           Offer[]
  watchlistEntries Watchlist[] @relation("ItemWatchlist")

  @@index([pawnShopId, status, isDeleted])
  @@index([category, status, isDeleted])
  @@index([createdAt])
}

model Inquiry {
  id            String   @id @default(cuid())
  itemId        String
  consumerEmail String
  message       String
  createdAt     DateTime @default(now())
  item          Item     @relation(fields: [itemId], references: [id])

  @@index([itemId, createdAt])
  @@index([consumerEmail])
}

model Auction {
  id                 String        @id @default(cuid())
  itemId             String        @unique
  shopId             String
  status             AuctionStatus @default(SCHEDULED)
  startingPrice      Decimal       @db.Decimal(10, 2)
  minIncrement       Decimal       @db.Decimal(10, 2)
  reservePrice       Decimal?      @db.Decimal(10, 2)
  buyItNowPrice      Decimal?      @db.Decimal(10, 2)
  startsAt           DateTime
  endsAt             DateTime
  antiSnipeWindowSec Int           @default(120)
  extendedEndsAt     DateTime?
  currentPrice       Decimal       @db.Decimal(10, 2)
  version            Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  ownerReviewedAt    DateTime?
  ownerReviewedById  String?
  item               Item          @relation(fields: [itemId], references: [id])
  shop               PawnShop      @relation(fields: [shopId], references: [id])
  bids               Bid[]
  settlement         Settlement?

  @@index([status, startsAt])
  @@index([status, endsAt])
  @@index([shopId, status])
  @@index([ownerReviewedAt])
  @@index([ownerReviewedById])
  @@index([createdAt])
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  userId    String
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([auctionId, amount])
  @@index([auctionId, createdAt])
  @@index([userId, auctionId])
}

model Settlement {
  id                  String           @id @default(cuid())
  auctionId           String           @unique
  winnerUserId        String
  finalPrice          Decimal          @db.Decimal(10, 2)
  status              SettlementStatus @default(PENDING)
  stripePaymentIntent String?          @unique
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  chargedAt           DateTime?
  currency            String           @default("USD")
  failedAt            DateTime?
  failureMessage      String?
  auction             Auction          @relation(fields: [auctionId], references: [id])
  winner              User             @relation("SettlementWinner", fields: [winnerUserId], references: [id])

  @@index([winnerUserId, status])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Offer {
  id             String      @id @default(cuid())
  itemId         String
  buyerId        String
  ownerId        String
  amount         Decimal     @db.Decimal(10, 2)
  message        String?
  status         OfferStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  counterAmount  Decimal?    @db.Decimal(10, 2)
  counterMessage String?
  respondedAt    DateTime?
  buyer          User        @relation("OfferBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  item           Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  owner          User        @relation("OfferOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([buyerId, createdAt])
  @@index([ownerId, createdAt])
  @@index([itemId, status])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())
  item      Item     @relation("ItemWatchlist", fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation("UserWatchlist", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, createdAt])
  @@index([itemId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  query     String
  createdAt DateTime @default(now())
  user      User     @relation("UserSavedSearches", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}


model BuyerItemSubmission {
  id             String   @id @default(cuid())
  buyerId        String
  title          String
  description    String?
  category       String?
  condition      String?
  estimatedValue Decimal? @db.Decimal(10, 2)
  images         String[] @default([])
  intent         String   @default("PAWN_OFFERS")
  radiusMiles    Int      @default(25)
  status         String   @default("SUBMITTED")
  reviewMessage  String?
  reviewedAt     DateTime?
  reviewedById   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  buyer  User @relation("BuyerItemSubmissions", fields: [buyerId], references: [id], onDelete: Cascade)
  offers BuyerItemSubmissionOffer[] @relation("BuyerItemSubmissionOffers")

  @@index([buyerId, createdAt])
  @@index([status, createdAt])
  @@index([intent, status])
}


model BuyerItemSubmissionOffer {
  id           String   @id @default(cuid())
  submissionId String
  shopId       String
  ownerId      String
  amount       Decimal  @db.Decimal(10, 2)
  message      String?
  status       String   @default("PENDING")
  respondedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission BuyerItemSubmission @relation("BuyerItemSubmissionOffers", fields: [submissionId], references: [id], onDelete: Cascade)
  shop       PawnShop            @relation("BuyerItemSubmissionOfferShop", fields: [shopId], references: [id], onDelete: Cascade)
  owner      User                @relation("BuyerItemSubmissionOfferOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([submissionId, status])
  @@index([shopId, createdAt])
  @@index([ownerId, createdAt])
  @@index([status, createdAt])
}

model InventoryImportJob {
  id           String                @id @default(cuid())
  userId       String
  shopId       String
  filename     String
  status       InventoryImportStatus @default(PENDING)
  totalRows    Int                   @default(0)
  successCount Int                   @default(0)
  failedCount  Int                   @default(0)
  errorsJson   Json?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  shop         PawnShop              @relation("ShopInventoryImportJobs", fields: [shopId], references: [id], onDelete: Cascade)
  user         User                  @relation("UserInventoryImportJobs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([shopId, createdAt])
}

model InventoryIntegration {
  id                   String                     @id @default(cuid())
  ownerId              String
  shopId               String
  name                 String
  type                 String                     @default("CSV_UPLOAD")
  provider             String?
  status               String                     @default("NEEDS_SETUP")
  baseUrl              String?
  inventoryEndpoint    String?
  authType             String                     @default("NONE")
  credentialHint       String?
  encryptedCredentials Json?
  syncFrequencyMinutes Int?
  lastSyncAt           DateTime?
  nextSyncAt           DateTime?
  metadata             Json?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  owner                User                       @relation("UserInventoryIntegrations", fields: [ownerId], references: [id], onDelete: Cascade)
  shop                 PawnShop                   @relation("ShopInventoryIntegrations", fields: [shopId], references: [id], onDelete: Cascade)
  syncJobs             InventorySyncJob[]
  externalMappings     ExternalInventoryMapping[]
  fieldMappings        InventoryFieldMapping[]
  webhookEvents        IntegrationWebhookEvent[]

  @@index([ownerId, createdAt])
  @@index([shopId, status])
  @@index([type, status])
}

model InventorySyncJob {
  id            String               @id @default(cuid())
  integrationId String
  shopId        String
  status        String               @default("PENDING")
  startedAt     DateTime?
  finishedAt    DateTime?
  createdCount  Int                  @default(0)
  updatedCount  Int                  @default(0)
  skippedCount  Int                  @default(0)
  errorCount    Int                  @default(0)
  errorSummary  Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  integration   InventoryIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  shop          PawnShop             @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
  @@index([shopId, createdAt])
  @@index([status, createdAt])
}

model ExternalInventoryMapping {
  id            String               @id @default(cuid())
  integrationId String
  externalId    String
  itemId        String?
  lastSeenAt    DateTime             @default(now())
  sourceHash    String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  integration   InventoryIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalId])
  @@index([itemId])
  @@index([lastSeenAt])
}

model InventoryFieldMapping {
  id            String               @id @default(cuid())
  integrationId String
  externalField String
  internalField String
  transformRule String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  integration   InventoryIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalField, internalField])
  @@index([integrationId])
}

model IntegrationWebhookEvent {
  id             String               @id @default(cuid())
  integrationId  String
  eventType      String
  payload        Json
  signatureValid Boolean              @default(false)
  status         String               @default("PENDING")
  processedAt    DateTime?
  createdAt      DateTime             @default(now())
  integration    InventoryIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
  @@index([status, createdAt])
}

enum Role {
  OWNER
  CONSUMER
  ADMIN
  SUPER_ADMIN
}

enum ItemStatus {
  AVAILABLE
  PENDING
  SOLD
}

enum AuctionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELED
}

enum SettlementStatus {
  PENDING
  CHARGED
  FAILED
  CANCELED
  REFUNDED
}

enum BuyerSubscriptionPlan {
  FREE
  PLUS
  PREMIUM
  ULTRA
}

enum BuyerSubscriptionStatus {
  UNKNOWN
  ACTIVE
  TRIALING
  PAST_DUE
  INCOMPLETE
  INCOMPLETE_EXPIRED
  CANCELED
  PAUSED
}

enum BillingInterval {
  MONTH
  YEAR
}

enum InventoryImportStatus {
  PENDING
  COMPLETED
  FAILED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  CANCELED
}

model PlatformSetting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String?
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy User? @relation("PlatformSettingUpdatedByUser", fields: [updatedByUserId], references: [id])

  @@index([key])
  @@index([updatedByUserId])
}

model SuperAdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorRole  String?
  action     String
  method     String
  path       String
  routeKey   String?
  targetType String?
  targetId   String?
  statusCode Int?
  success    Boolean  @default(true)
  requestId  String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([actorEmail, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([success, createdAt])
}

enum StaffRole {
  SHOP_ADMIN
  SHOP_MANAGER
  SHOP_STAFF
  SHOP_VIEWER
  INVENTORY_MANAGER
  AUCTION_MANAGER
  SALES_ASSOCIATE
  FINANCE_VIEWER
}

enum StaffStatus {
  INVITED
  ACTIVE
  INACTIVE
  ARCHIVED
}
