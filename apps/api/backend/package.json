{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:core",
    "dev": "nodemon --watch src --ext js --exec node src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test:core": "prisma generate && node --test --test-concurrency=1 test/app.contract.test.js test/stripe.subscription-price-validation.test.js test/marketplaceTransactionPayment.service.test.js test/marketplaceTransactionPaymentWebhook.service.test.js test/marketplaceTransactionReservationRelease.service.test.js test/itemIntake.service.test.js",
    "test:integration": "node scripts/assert-test-database.mjs && prisma migrate deploy && prisma generate && node --test --test-concurrency=1 test/*.integration.test.js",
    "test:all": "npm run test:core && npm run test:integration",
    "build:combined": "bash scripts/build-combined-service.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "9.0.3",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2"
  }
}
